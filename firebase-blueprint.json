{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["buyer", "seller", "dealer", "admin"] },
        "isProfileComplete": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "A vehicle saved by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "vehicleId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "vehicleId"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "A vehicle listing",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "number" },
        "vehicleType": { "type": "string" },
        "fuelType": { "type": "string" },
        "transmission": { "type": "string" },
        "kilometersDriven": { "type": "number" },
        "ownership": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "sellerId": { "type": "string" },
        "shopId": { "type": "string" },
        "status": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "sellerId"]
    },
    "Shop": {
      "title": "Shop",
      "description": "A car showroom or shop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "phone": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "ownerId": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "address", "city"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/wishlists/{wishlistId}": {
      "schema": "WishlistItem",
      "description": "User wishlist items"
    },
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Vehicle listings"
    },
    "/shops/{shopId}": {
      "schema": "Shop",
      "description": "Car showroom listings"
    }
  }
}
